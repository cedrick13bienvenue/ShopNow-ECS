{
  "family": "order-service",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::ACCOUNT_ID:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "order-service",
      "image": "ACCOUNT_ID.dkr.ecr.eu-west-1.amazonaws.com/shopnow/order-service:IMAGE_TAG",
      "portMappings": [
        {
          "name": "order-service-3004",
          "containerPort": 3004,
          "protocol": "tcp",
          "appProtocol": "http"
        }
      ],
      "environment": [
        { "name": "NODE_ENV",       "value": "production" },
        { "name": "DB_HOST",        "value": "REPLACE_DB_HOST" },
        { "name": "DB_PORT",        "value": "5432" },
        { "name": "DB_NAME",        "value": "shopnow" },
        { "name": "DB_USER",        "value": "REPLACE_DB_USER" },
        { "name": "DB_PASSWORD",    "value": "REPLACE_DB_PASSWORD" },
        { "name": "JWT_SECRET",     "value": "REPLACE_JWT_SECRET" },
        { "name": "CART_SERVICE_URL", "value": "http://cart-service-3003.shopnow.local:3003" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group":         "/ecs/order-service",
          "awslogs-region":        "eu-west-1",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "essential": true
    }
  ],
  "serviceConnectConfiguration": {
    "enabled": false
  }
}
