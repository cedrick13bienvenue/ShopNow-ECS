# Copy this file to .env and fill in your values
# cp .env.example .env

# ─────────────────────────────────────────
# AWS
# ─────────────────────────────────────────
AWS_REGION=eu-west-1
AWS_ACCOUNT_ID=                        # e.g. 414392949441

# ─────────────────────────────────────────
# ECS Clusters
# ─────────────────────────────────────────
AUTH_CLUSTER=shopnow-auth-cluster
PRODUCTS_CLUSTER=shopnow-products-cluster
CORE_CLUSTER=shopnow-core-cluster

# ─────────────────────────────────────────
# ECR
# ─────────────────────────────────────────
ECR_REGISTRY=                          # <account-id>.dkr.ecr.eu-west-1.amazonaws.com

# ─────────────────────────────────────────
# Service ports
# ─────────────────────────────────────────
PORT_AUTH=3001
PORT_PRODUCT=3002
PORT_CART=3003
PORT_ORDER=3004

# ─────────────────────────────────────────
# RDS — PostgreSQL  (local: use postgres / AWS: override via ECS task def)
# ─────────────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_USER=shopnow
DB_PASSWORD=                           # local: shopnow / AWS: your RDS password
DB_NAME_AUTH=shopnow_auth
DB_NAME_PRODUCTS=shopnow_products
DB_NAME_ORDERS=shopnow_orders

# ─────────────────────────────────────────
# ElastiCache — Redis  (local: use redis / AWS: override via ECS task def)
# ─────────────────────────────────────────
REDIS_URL=redis://redis:6379
REDIS_HOST=redis
REDIS_PORT=6379

# ─────────────────────────────────────────
# Auth / JWT
# ─────────────────────────────────────────
JWT_SECRET=                            # any secret string for local dev

# ─────────────────────────────────────────
# S3 + CloudFront (product-service — leave blank to use local disk storage)
# ─────────────────────────────────────────
S3_BUCKET=
CLOUDFRONT_DOMAIN=
