# Copy this file to .env and fill in your values
# cp .env.example .env

# ─────────────────────────────────────────
# AWS
# ─────────────────────────────────────────
AWS_REGION=
AWS_ACCOUNT_ID=

# ─────────────────────────────────────────
# ECS Clusters
# ─────────────────────────────────────────
AUTH_CLUSTER=
PRODUCTS_CLUSTER=
CORE_CLUSTER=

# ─────────────────────────────────────────
# ECR
# ─────────────────────────────────────────
ECR_REGISTRY=

# ─────────────────────────────────────────
# Service ports
# ─────────────────────────────────────────
PORT_AUTH=
PORT_PRODUCT=
PORT_CART=
PORT_ORDER=

# ─────────────────────────────────────────
# RDS — PostgreSQL
# ─────────────────────────────────────────
DB_HOST=
DB_PORT=
DB_USER=
DB_PASSWORD=
DB_NAME_AUTH=
DB_NAME_PRODUCTS=
DB_NAME_ORDERS=

# ─────────────────────────────────────────
# ElastiCache — Redis
# ─────────────────────────────────────────
REDIS_URL=
REDIS_HOST=
REDIS_PORT=

# ─────────────────────────────────────────
# Auth / JWT
# ─────────────────────────────────────────
JWT_SECRET=

# ─────────────────────────────────────────
# S3 + CloudFront (product-service only)
# Leave S3_BUCKET empty locally — uses local disk storage instead of S3
# AWS: set these in the ECS task definition
# ─────────────────────────────────────────
S3_BUCKET=
CLOUDFRONT_DOMAIN=
