# ─────────────────────────────────────────
# AWS
# ─────────────────────────────────────────
AWS_REGION=eu-west-1
AWS_ACCOUNT_ID=                        # e.g. 41439xxxxxxx

# ─────────────────────────────────────────
# ECS Clusters
# ─────────────────────────────────────────
AUTH_CLUSTER=shopnow-auth-cluster
PRODUCTS_CLUSTER=shopnow-products-cluster
CORE_CLUSTER=shopnow-core-cluster

# ─────────────────────────────────────────
# ECR
# ─────────────────────────────────────────
ECR_REGISTRY=                          # <account-id>.dkr.ecr.eu-west-1.amazonaws.com

# ─────────────────────────────────────────
# Service Connect / Cloud Map
# ─────────────────────────────────────────
SERVICE_CONNECT_NAMESPACE=shopnow.local

# ─────────────────────────────────────────
# Service ports
# ─────────────────────────────────────────
PORT_AUTH=3001
PORT_PRODUCT=3002
PORT_CART=3003
PORT_ORDER=3004

# ─────────────────────────────────────────
# Service Connect DNS names (used on AWS)
# ─────────────────────────────────────────
AUTH_SERVICE_URL=http://auth-service:3001
PRODUCT_SERVICE_URL=http://product-service:3002
CART_SERVICE_URL=http://cart-service:3003
ORDER_SERVICE_URL=http://order-service:3004

# ─────────────────────────────────────────
# RDS — PostgreSQL  (AWS: override via ECS task def)
# ─────────────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_USER=shopnow
DB_PASSWORD=shopnow
DB_NAME_AUTH=shopnow_auth
DB_NAME_PRODUCTS=shopnow_products
DB_NAME_ORDERS=shopnow_orders

# ─────────────────────────────────────────
# ElastiCache — Redis  (AWS: override via ECS task def)
# ─────────────────────────────────────────
REDIS_URL=redis://redis:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# ─────────────────────────────────────────
# Auth / JWT  (AWS: override via ECS task def)
# ─────────────────────────────────────────
JWT_SECRET=shopnow-dev-secret

# ─────────────────────────────────────────
# S3 + CloudFront (product-service only)
# ─────────────────────────────────────────
S3_BUCKET=shopnow-product-images
CLOUDFRONT_DOMAIN=                     # e.g. d1abc123.cloudfront.net
