AWS_ACCOUNT_ID=''
AWS_REGION='us-east-1'
JWT_SECRET=''

# ECS Cluster names
ECS_CLUSTER_1='shopnow-cluster-1'
ECS_CLUSTER_2='shopnow-cluster-2'
ECS_CLUSTER_3='shopnow-cluster-3'

# Cloud Map namespace for Service Connect (spans all 3 clusters)
SERVICE_CONNECT_NAMESPACE='shopnow.local'

# Service Connect DNS names (used in AWS instead of container names)
AUTH_SERVICE_URL='http://shopnow-auth:3001'
PRODUCT_SERVICE_URL='http://shopnow-product:3002'
CART_SERVICE_URL='http://shopnow-cart:3003'

# Ports
PORT_AUTH=3001
PORT_PRODUCT=3002
PORT_CART=3003
PORT_ORDER=3004
